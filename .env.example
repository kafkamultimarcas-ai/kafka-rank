# Copie este arquivo para `.env` e preencha os valores reais. Nenhuma dessas
# chaves deve ser commitada com valor real — este arquivo é só documentação.

# ===== Banco de dados =====
DATABASE_URL="mysql://root:root123@localhost:3307/kafka_rank"

# ===== Autenticação =====
JWT_SECRET="troque-por-um-segredo-forte-em-producao"

# ===== OAuth (login do proprietário/Manus) =====
VITE_APP_ID=""
OAUTH_SERVER_URL="https://api.manus.im"
OWNER_OPEN_ID=""

# ===== Forge (integração interna, se aplicável) =====
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""

# ===== Z-API (WhatsApp) =====
ZAPI_INSTANCE_ID=""
ZAPI_TOKEN=""
ZAPI_API_URL="https://api.z-api.io"
ZAPI_CLIENT_TOKEN=""

# ===== ASAAS (cobrança/assinatura) =====
ASAAS_API_URL="https://api-sandbox.asaas.com/v3"
ASAAS_API_KEY=""
# Token fixo cadastrado no painel ASAAS ao criar o webhook — validado contra o
# header `asaas-access-token` em server/webhooks.ts.
ASAAS_WEBHOOK_TOKEN=""

# ===== E-mail transacional (Resend) =====
# Sem essa chave, e-mails caem em log (console) em vez de serem enviados de
# verdade — comportamento normal em dev.
RESEND_API_KEY=""

# ===== Push notifications =====
VITE_VAPID_PUBLIC_KEY=""

# ===== Analytics =====
VITE_ANALYTICS_ENDPOINT=""
VITE_ANALYTICS_WEBSITE_ID=""

# ===== Aplicação =====
# Origem pública usada por jobs em background que montam link absoluto sem
# ter uma request HTTP de onde derivar o host.
APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV="development"

# ===== Observabilidade =====
# Nível de log do server/_core/logger.ts (pino): trace|debug|info|warn|error|fatal
LOG_LEVEL="info"
